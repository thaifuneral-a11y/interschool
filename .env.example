# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME="International Student Care OS"
ENVIRONMENT=development          # development | production
DEBUG=true

# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/intersos

# ─── JWT Auth ───────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32_output
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ─── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Email (SendGrid) ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourschool.edu
FROM_NAME="International Student Care OS"

# ─── Firebase Push Notifications ────────────────────────────────────────────────
# Paste the entire content of your Firebase service account JSON, minified, as a single string
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── Supabase Storage ───────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Sentry (optional) ──────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxxxxxx@sentry.io/xxxxxxx

# ─── Frontend (Next.js) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
